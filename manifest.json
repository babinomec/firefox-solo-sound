{
  "manifest_version": 2,
  "name": "Solo Sound",
  "version": "1.0",
  "description": "Only one tab plays sound at a time. When a tab starts playing audio or gets unmuted, all other audible tabs are automatically muted.",
  "permissions": ["tabs"],
  "browser_specific_settings": {
    "gecko": {
      "id": "{a61c32d6-fecc-4aad-a680-4beb7da0913d}",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "icons": {
    "48": "icon.svg",
    "128": "icon.svg"
  },
  "background": {
    "scripts": ["background.js"]
  }
}
